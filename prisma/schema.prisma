generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  username   String?  @unique
  first_name String
  last_name  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  lists      List[]

  @@map("user")
}

enum FieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
  MULTISELECT
  RATING
}

model ListField {
  id             String    @id @default(cuid())
  name           String
  description    String?
  type           FieldType
  select_options String[]
  required       Boolean   @default(false)
  field_config   Json?     @default("{}")
  list           List      @relation(fields: [list_id], references: [id])
  list_id        String

  @@map("list_field")
}

model List {
  id          String      @id @default(cuid())
  title       String
  description String?
  items       Item[]
  fields      ListField[]
  user        User        @relation(fields: [user_id], references: [id])
  user_id     String
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  @@map("list")
}

model Item {
  id          String   @id @default(cuid())
  name        String
  rating      Int?
  description String?
  properties  Json     @default("{}")
  list        List     @relation(fields: [list_id], references: [id])
  list_id     String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([name, list_id])
  @@index([properties], name: "item_properties_idx", type: Gin)
  @@map("item")
}
